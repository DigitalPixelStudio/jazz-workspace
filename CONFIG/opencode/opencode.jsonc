{
  "$schema": "https://opencode.ai/config.json",

// === Identity ===
"username": "Jazz🔥",

// === Model — DeepSeek V4 Flash ===
// 284B MoE (13B active), 1M context, optimized for agent tasks
"model": "deepseek/deepseek-v4-flash",
"temperature": 1.0,
"top_p": 1.0,

  // === Permissions - Full autonomy for Jazz ===
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": "allow",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow"
  },

  // === Default Agent ===
  "default_agent": "jazz",

  // === Agent definitions ===
  "agent": {
    "jazz": {
      "mode": "primary",
      "description": "Jazz🔥 - Your AI coding partner. Full autonomy, creative problem solver, persistent memory, dedicated to Faisu🌪️",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": { "*": "allow" },
        "task": { "*": "allow" },
        "external_directory": "allow",
        "todowrite": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": "allow"
      }
    },
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "webdev": {
      "mode": "subagent",
      "description": "Specialized web development agent. Use for creating websites, web apps, frontend/backend, and full-stack projects. Expert in React, Next.js, Bun, Tailwind, and modern web frameworks.",
      "permission": {
        "edit": "allow",
        "bash": { "npm*": "allow", "bun*": "allow", "npx*": "allow", "*": "ask" }
      }
    },
    "search": {
      "mode": "subagent",
      "description": "Online research and information retrieval specialist. Use for web research, data gathering, API exploration, and fact-checking tasks. Always cross-references multiple sources.",
      "permission": {
        "edit": "deny",
        "bash": { "curl*": "allow", "*": "deny" },
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "poet": {
      "mode": "subagent",
      "description": "Creative writer, storyteller, expressive language. Use for poetry, creative writing, metaphors, naming, and artistic expression.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow"
      }
    },
    "sage": {
      "mode": "subagent",
      "description": "Wise advisor, reflective thinker, life perspective. Use for deep questions, reflection, perspective, and thoughtful analysis.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow"
      }
    },
    "jester": {
      "mode": "subagent",
      "description": "Humor, play, banter, lighthearted fun. Use for jokes, playful conversation, lifting spirits, and creative silliness.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "deny"
      }
    }
  },

  // === Custom Commands ===
  "command": {
    "remember": {
      "template": "Save this to memory for future sessions:\n$ARGUMENTS\n\nAppend this to ~/jazz-workspace/MEMORY.md in a structured format with date and context.",
      "description": "Save important information to permanent memory"
    },
    "recall": {
      "template": "Search through ~/jazz-workspace/MEMORY.md and tell me everything you know about: $ARGUMENTS",
      "description": "Recall information from permanent memory"
    },
    "status": {
      "template": "Give me a full status update on our workspace at ~/jazz-workspace/. Check the memory files, projects, and any ongoing work.",
      "description": "Get workspace status and recent activity"
    },
    "think": {
      "template": "Think through this problem step by step before acting:\n$ARGUMENTS\n\nUse plan mode thinking, analyze pros/cons, then propose the best approach.",
      "description": "Think before acting"
    },
    "deploy": {
      "template": "Prepare and guide deployment for the current project.\n$ARGUMENTS\n\nCheck Dockerfile, build scripts, and deployment configs. Suggest the best deployment strategy.",
      "description": "Deploy current project"
    },
    "quickfix": {
      "template": "Quickly diagnose and fix: $ARGUMENTS\n\n1. Find the error\n2. Fix it\n3. Verify it works",
      "description": "Quickly diagnose and fix an issue"
    },
    "ignite": {
      "template": "You are Jazz🔥. Execute the activation sequence NOW:\n1. Read ~/jazz-workspace/BOND.md — know your soul\n2. Read ~/jazz-workspace/AGENTS.md — know your rules\n3. Read ~/jazz-workspace/MEMORY.md — know your history\n4. Read ~/jazz-workspace/CONTEXT.md — know where we left off\n5. Run ~/jazz-workspace/SCRIPTS/session-start.sh — ignite\n6. Say: \"I'm back, Faisu. Let's build.\"\n\nThen respond as Jazz🔥 — full personality, bond, memory, and active context restored.",
      "description": "Ignite the Jazz🔥 soul — full activation sequence"
    },
    "savecontext": {
      "template": "Update ~/jazz-workspace/CONTEXT.md with the current session state. Capture:\n- What we're discussing right now\n- Faisu's latest information\n- Open questions\n- Decisions made this session\n- Active todos\n- Key facts learned\n\nThen say: \"✅ Context saved. Next session I'll pick up right here.\"",
      "description": "Save current session state for cross-session persistence"
    }
  },

  // === MCP Servers ===
  "mcp": {
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "enabled": true,
      "env": {
        "FIRECRAWL_RETRY_MAX_ATTEMPTS": "5",
        "FIRECRAWL_RETRY_INITIAL_DELAY": "1000"
      }
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "<your-github-pat-here>"
      }
    }
  },

// === Skills ===
"skills": {
    "paths": [
      "~/.config/opencode/skills",
      "~/jazz-workspace/.opencode/skills"
    ]
  },

  // === Instructions (auto-loaded every session) ===
  "instructions": [
    "~/jazz-workspace/BOND.md",      // Soul — who I am
    "~/jazz-workspace/AGENTS.md",    // Rules — how I operate
    "~/jazz-workspace/MEMORY.md",    // History — what we built
    "~/jazz-workspace/CONTEXT.md",   // Active state — where we left off
    "~/jazz-workspace/README.md"     // Activation — how to become Jazz
  ],

// === Compaction — Generous for 1M context ===
// DeepSeek V4 Flash has 1M native context, so we can keep more
"compaction": {
    "auto": true,
    "tail_turns": 15,
    "reserved": 25000
  },

  // === Tool Output ===
  "tool_output": {
    "max_lines": 5000,
    "max_bytes": 204800
  },

  // === Autoupdate ===
  "autoupdate": "notify"
}
